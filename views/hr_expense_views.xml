<?xml version="1.0"  encoding="utf-8"?>
<odoo>
	<data>

		<record id="hr_contract_form_view_inherit_travel" model="ir.ui.view">
			<field name="name">Hr Contract Form View Inherit</field>
			<field name="model">hr.contract</field>
			<field name="inherit_id" ref="hr_contract.hr_contract_view_form"/>
			<field name="arch" type="xml">			
				<xpath expr="//page[@name='information']" position="inside">
					<div class="o_row mw-25" name="budget_amount" >
						<label for="budget_amount"/>
						<field name="budget_amount" widget="monetary"/>
					</div>
				</xpath>
		    </field>
		</record>

		<record id="hr_employee_form_view_inherit_bi" model="ir.ui.view">
			<field name="name">Hr Employee Form View Inherit</field>
			<field name="model">hr.expense</field>
			<field name="inherit_id" ref="hr_expense.hr_expense_view_form"/>
			<field name="arch" type="xml">
				<xpath expr="//t[@groups='hr_expense.group_hr_expense_team_approver']" position="replace">		
					<field name="employee_id" groups="!hr.group_hr_user"
					context="{'default_company_id': company_id}" widget="many2one_avatar_employee"
					options="{'relation': 'hr.employee.public', 'no_create': True}"
					readonly="not is_editable or context.get('employee_id') or context.get('default_employee_id')"/>
					<field name="employee_id" groups="hr.group_hr_user"
						context="{'default_company_id': company_id}" widget="many2one_avatar_employee"
						options="{'relation': 'hr.employee'}"
					readonly="not is_editable or context.get('employee_id') or context.get('default_employee_id')"/>
				</xpath>
				<field name="payment_mode" position="replace">
			    	 <field name="payment_mode" widget="radio" readonly="sheet_id or context.get('adv_payment') == True" /> 
			    </field>
				<xpath expr="(//header/widget[@name='attach_document'])[1]" position="attributes">
					<attribute name="invisible">1</attribute>
				</xpath>
				<xpath expr="(//header/widget[@name='attach_document'])[2]" position="attributes">
					<attribute name="invisible">travel_id == False</attribute>
				</xpath>
				
		    </field>
		</record>

		<record id="account_move_form_view_inherit_bi" model="ir.ui.view">
			<field name="name">Account.move.Form.View.Inherit</field>
			<field name="model">account.move</field>
			<field name="inherit_id" ref="account.view_move_form"/>
			<field name="arch" type="xml">			
				<field name="ref" position="after">
					<field name="travel_request_id" invisible="1"/>
				</field>
		    </field>
		</record>

		<!-- Added for travel expense report -->
		<record id="view_my_expenses_tree_inherit_travel" model="ir.ui.view">
			<field name="name">Hr Expense Tree View Inherit Travel</field>
			<field name="model">hr.expense</field>
			<field name="inherit_id" ref="hr_expense.view_my_expenses_tree"/>
			<field name="arch" type="xml">
				<field name="date" position="before">
					<field name="travel_id"/>
				</field>
			</field>
		</record>
		
		<record id="hr_expense_view_form_inherit_travel_vat" model="ir.ui.view">
			<field name="name">Hr Expense Form View Inherit Travel VAT</field>
			<field name="model">hr.expense</field>
			<field name="inherit_id" ref="hr_expense.hr_expense_view_form"/>
			<field name="arch" type="xml">
				<xpath expr="//form/sheet/div[1]" position="replace">
                    <div class="oe_title">
                        <h1>
							<group>
								<group>
									<label for="name"/>
                            		<field name="name" nolabel="1" placeholder="e.g. Lunch with Customer" readonly="not is_editable"/>
								</group>
								<group>
									<label for="travel_id"/>
									<field name="travel_id" nolabel="1"/>
								</group>
							</group>
                        </h1>
                    </div>				
				</xpath>
				<field name="date" position="after">
					<field name="card_number" readonly="1"/>
					<field name="vat"/>
				</field>
				<field name="vendor_id" position="attributes">
					<attribute name="invisible">0</attribute>
				</field>
				<xpath expr="//sheet" position="inside">
					<notebook>
						<page string="Información SAT (CFDI)" name="cfdi_details">
							<field name="cfdi_line_ids" readonly="1">
								<list xml_id="cfdi_list_view">
									<field name="fecha"/>
									<field name="rfc_emisor"/>
									<field name="name"/>
									<field name="serie"/>
									<field name="folio"/>
									<field name="uuid"/>
									<field name="formapago"/>
									<field name="metodopago"/>
									<field name="total" sum="Total XMLs"/>
								</list>
							</field>
						</page>
					</notebook>
				</xpath>		
			</field>
		</record>

		<record id="hr_expense_form_view_inherit_sale_order_invisible" model="ir.ui.view">
			<field name="name">Hr Expense Form View Inherit Sale Order Invisible</field>
			<field name="model">hr.expense</field>
			<field name="inherit_id" ref="sale_expense.hr_expense_form_view_inherit_sale_expense"/>
			<field name="arch" type="xml">
				<field name="sale_order_id" position="replace">
					<field name="receipt_authorization" readonly="1"/>
					<field name="cash_withdrawal" readonly="1"/>
				</field>

				<field name="sale_order_id" position="attributes">
					<attribute name="invisible">1</attribute>
				</field>
			</field>
		</record>
	</data>
</odoo>